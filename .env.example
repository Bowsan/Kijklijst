# --- Op de Bank: backend configuratie ---

# Vereist: jouw TMDb API v3 sleutel (https://www.themoviedb.org/settings/api)
# De sleutel blijft op de server en komt nooit in de frontend terecht.
TMDB_API_KEY=

# Poort waarop de server luistert (binnen de container)
PORT=8080

# Pad naar het SQLite-bestand. In Docker wordt /data gemount als volume.
DATABASE_PATH=./data/opdebank.sqlite

# Taal/regio voor TMDb (Nederland)
TMDB_LANGUAGE=nl-NL
TMDB_REGION=NL
